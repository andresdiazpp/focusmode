<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Nombre único del servicio — tiene que coincidir con helperMachServiceName -->
    <key>Label</key>
    <string>com.andresdiazpp.focusmode.helper</string>

    <!-- Ruta al ejecutable relativa al bundle de la app.
         BundleProgram (en vez de Program) permite que macOS encuentre el helper
         sin importar dónde esté instalada la app — no hay path hardcodeado. -->
    <key>BundleProgram</key>
    <string>Contents/Library/LaunchServices/com.andresdiazpp.focusmode.helper</string>

    <!-- El helper escucha conexiones XPC por este nombre -->
    <key>MachServices</key>
    <dict>
        <key>com.andresdiazpp.focusmode.helper</key>
        <true/>
    </dict>

    <!-- Solo la app principal puede activar el helper -->
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.andresdiazpp.FocusMode</string>
    </array>
</dict>
</plist>
